pipeline {
    agent {
        docker {
            image 'vlamguard:latest'
            args '--entrypoint=""'
        }
    }

    environment {
        VLAM_AI_BASE_URL = credentials('vlam-ai-url')
        VLAM_AI_MODEL = 'llama3.2'
    }

    stages {
        stage('VlamGuard Risk Analysis') {
            steps {
                sh '''
                    vlamguard check \
                        --chart ./helm-chart \
                        --values ./values-${DEPLOY_ENV}.yaml \
                        --env ${DEPLOY_ENV} \
                        --output markdown \
                        --output-file vlamguard-report.md
                '''
            }
            post {
                always {
                    archiveArtifacts artifacts: 'vlamguard-report.md', allowEmptyArchive: true
                }
                failure {
                    echo 'VlamGuard: Deployment BLOCKED due to policy violations.'
                }
            }
        }

        stage('VlamGuard Without AI (Fallback)') {
            when {
                expression { currentBuild.previousBuild?.result == 'FAILURE' }
            }
            steps {
                sh '''
                    vlamguard check \
                        --chart ./helm-chart \
                        --values ./values-${DEPLOY_ENV}.yaml \
                        --env ${DEPLOY_ENV} \
                        --skip-ai \
                        --output markdown \
                        --output-file vlamguard-report-no-ai.md
                '''
            }
            post {
                always {
                    archiveArtifacts artifacts: 'vlamguard-report-no-ai.md', allowEmptyArchive: true
                }
            }
        }
    }
}
